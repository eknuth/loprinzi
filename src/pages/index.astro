---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="World Famous Since 1948" description="Loprinzi's Gym — Portland's legendary fitness institution since 1948. No contracts. No initiation fees. Real iron, real results.">

  <!-- Hero -->
  <section
    style="position: relative; min-height: 90vh; display: flex; flex-direction: column; justify-content: flex-end; overflow: hidden;"
    aria-label="Loprinzi's Gym hero"
  >
    <!-- Background image -->
    <img
      src={base + "/images/gym-panorama.jpg"}
      alt="Interior panorama of Loprinzi's Gym showing decades of iron and equipment"
      width="1600"
      height="900"
      style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center;"
    />
    <!-- Dark overlay -->
    <div class="hero-overlay" style="position: absolute; inset: 0;"></div>

    <!-- Hero content -->
    <div style="position: relative; z-index: 2; max-width: 1200px; margin: 0 auto; padding: 4rem 1.5rem 5rem; width: 100%;">
      <p style="font-family: var(--font-display); font-weight: 700; font-size: 0.9rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-gold); margin-bottom: 0.75rem;">
        Portland, Oregon
      </p>
      <h1 style="font-family: var(--font-display); font-weight: 900; font-size: clamp(4rem, 12vw, 9rem); letter-spacing: 0.06em; text-transform: uppercase; color: #fff; line-height: 0.9; margin-bottom: 0.5rem;">
        Loprinzi's
      </h1>
      <div style="display: flex; align-items: center; gap: 1.5rem; margin-bottom: 1.5rem; flex-wrap: wrap;">
        <span style="height: 3px; width: 60px; background: var(--color-coral); display: block; flex-shrink: 0;"></span>
        <p style="font-family: var(--font-display); font-weight: 600; font-size: clamp(1rem, 3vw, 1.5rem); letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-cream); opacity: 0.9; margin: 0;">
          World Famous Since 1948
        </p>
      </div>
      <p style="font-size: clamp(1rem, 2vw, 1.2rem); color: rgba(245,240,235,0.8); max-width: 520px; line-height: 1.65; margin-bottom: 2.5rem;">
        Portland's original iron paradise. Built by the Loprinzi family. Preserved by those who love it.
        No contracts. No initiation fees. Just the best workout of your life.
      </p>
      <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
        <a
          href={base + "/rates"}
          style="display: inline-block; background: var(--color-coral); color: #fff; font-family: var(--font-display); font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.875rem 2rem; font-size: 0.95rem; text-decoration: none; transition: background 0.2s; cursor: pointer;"
          onmouseover="this.style.background='var(--color-coral-dark)'"
          onmouseout="this.style.background='var(--color-coral)'"
        >
          View Rates
        </a>
        <a
          href={base + "/history"}
          style="display: inline-block; border: 2px solid rgba(245,240,235,0.5); color: var(--color-cream); font-family: var(--font-display); font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.875rem 2rem; font-size: 0.95rem; text-decoration: none; transition: border-color 0.2s, color 0.2s; cursor: pointer;"
          onmouseover="this.style.borderColor='var(--color-gold)'; this.style.color='var(--color-gold)'"
          onmouseout="this.style.borderColor='rgba(245,240,235,0.5)'; this.style.color='var(--color-cream)'"
        >
          Our Story
        </a>
      </div>
    </div>

    <!-- Scroll hint -->
    <div style="position: absolute; bottom: 1.5rem; right: 2rem; z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 0.4rem; opacity: 0.5;">
      <span style="font-family: var(--font-display); font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-cream); writing-mode: vertical-rl;">Scroll</span>
      <svg width="1" height="40" viewBox="0 0 1 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <line x1="0.5" y1="0" x2="0.5" y2="40" stroke="var(--color-cream)" stroke-width="1"/>
      </svg>
    </div>
  </section>

  <!-- Red motto banner -->
  <div class="red-banner" role="banner">
    "Good Health — Your Most Valuable Possession"
  </div>

  <!-- Services section -->
  <section style="padding: 5rem 1.5rem; background: var(--color-cream);" aria-labelledby="services-heading">
    <div style="max-width: 1200px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 3.5rem;">
        <p class="section-subtitle" style="margin-bottom: 0.5rem;">What We Offer</p>
        <h2 id="services-heading" class="section-title" style="font-size: clamp(2rem, 5vw, 3rem);">
          Complete Fitness, Proven Since '48
        </h2>
        <p style="max-width: 540px; margin: 1rem auto 0; color: var(--color-warm-gray); font-size: 1rem; line-height: 1.7;">
          Every piece of equipment, every class, every square foot of this gym has been curated over
          decades to give you the most effective workout available.
        </p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem;">

        <!-- Endurance -->
        <div class="card fade-up" style="padding: 2rem;">
          <div style="width: 48px; height: 48px; background: var(--color-navy); border-radius: 4px; display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
          </div>
          <h3 style="font-family: var(--font-display); font-weight: 800; font-size: 1.5rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-navy); margin-bottom: 0.5rem;">
            Endurance
          </h3>
          <div style="width: 36px; height: 3px; background: var(--color-coral); margin-bottom: 1rem;"></div>
          <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem;">
            {["Aerobics Classes", "Lifecycles", "Stairsteppers", "Treadmills", "Outdoor Pool"].map(item => (
              <li style="display: flex; align-items: center; gap: 0.75rem; font-size: 0.95rem; color: var(--color-charcoal);">
                <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-sage); flex-shrink: 0;"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Strength -->
        <div class="card fade-up" style="padding: 2rem; border-top: 4px solid var(--color-coral);">
          <div style="width: 48px; height: 48px; background: var(--color-coral); border-radius: 4px; display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6.5 6.5h11M6.5 17.5h11M3 12h18M6 8.5L3 12l3 3.5M18 8.5l3 3.5-3 3.5"/>
            </svg>
          </div>
          <h3 style="font-family: var(--font-display); font-weight: 800; font-size: 1.5rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-navy); margin-bottom: 0.5rem;">
            Strength
          </h3>
          <div style="width: 36px; height: 3px; background: var(--color-coral); margin-bottom: 1rem;"></div>
          <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem;">
            {["Free Weights", "Nautilus Machines", "Universal Equipment", "Back & Ab Classes", "World's First Mass-Produced Nautilus"].map(item => (
              <li style="display: flex; align-items: center; gap: 0.75rem; font-size: 0.95rem; color: var(--color-charcoal);">
                <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-coral); flex-shrink: 0;"></span>
                {item}
              </li>
            ))}
          </ul>
          <p style="font-size: 0.75rem; color: var(--color-warm-gray); margin-top: 0.75rem; font-style: italic;">
            &mdash; original handmade family equipment on display
          </p>
        </div>

        <!-- Flexibility -->
        <div class="card fade-up" style="padding: 2rem;">
          <div style="width: 48px; height: 48px; background: var(--color-sage); border-radius: 4px; display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 6v6l4 2"/>
            </svg>
          </div>
          <h3 style="font-family: var(--font-display); font-weight: 800; font-size: 1.5rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-navy); margin-bottom: 0.5rem;">
            Flexibility
          </h3>
          <div style="width: 36px; height: 3px; background: var(--color-sage); margin-bottom: 1rem;"></div>
          <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem;">
            {["Yoga Classes", "Stretching Programs", "Sauna", "Steam Room", "Recovery-Focused"].map(item => (
              <li style="display: flex; align-items: center; gap: 0.75rem; font-size: 0.95rem; color: var(--color-charcoal);">
                <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-sage); flex-shrink: 0;"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- No contracts callout -->
  <section style="background: var(--color-navy); padding: 4rem 1.5rem; text-align: center;" aria-label="Membership callout">
    <div style="max-width: 800px; margin: 0 auto;">
      <p class="section-subtitle" style="color: var(--color-gold); margin-bottom: 0.75rem;">The Loprinzi Way</p>
      <h2 style="font-family: var(--font-display); font-weight: 900; font-size: clamp(2rem, 6vw, 3.5rem); text-transform: uppercase; letter-spacing: 0.06em; color: #fff; margin-bottom: 1rem;">
        No Contracts.<br/>No Initiation Fees.
      </h2>
      <p style="color: rgba(245,240,235,0.75); font-size: 1.05rem; max-width: 560px; margin: 0 auto 2.5rem; line-height: 1.7;">
        We've operated on trust and results for over 75 years. Come in, work hard, come back.
        That's the only contract we've ever needed.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a
          href={base + "/rates"}
          style="display: inline-block; background: var(--color-coral); color: #fff; font-family: var(--font-display); font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.875rem 2.5rem; font-size: 1rem; text-decoration: none; transition: background 0.2s;"
        >
          See Membership Rates
        </a>
        <a
          href={base + "/contact"}
          style="display: inline-block; border: 2px solid var(--color-gold); color: var(--color-gold); font-family: var(--font-display); font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.875rem 2.5rem; font-size: 1rem; text-decoration: none; transition: background 0.2s, color 0.2s;"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>

  <!-- History teaser -->
  <section style="padding: 5rem 1.5rem; background: var(--color-cream-dark);" aria-labelledby="history-teaser-heading">
    <div style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;">
      <div>
        <p class="section-subtitle" style="margin-bottom: 0.5rem;">Est. 1948</p>
        <h2 id="history-teaser-heading" class="section-title" style="font-size: clamp(2rem, 5vw, 3rem); margin-bottom: 1.5rem;">
          A Legacy Forged in Iron
        </h2>
        <p style="color: var(--color-charcoal); line-height: 1.75; margin-bottom: 1.25rem; font-size: 1rem;">
          The Loprinzi family's story begins with Pasquale "Charles" Loprinzi, a Sicilian immigrant who sold vegetables on Portland streets. His sons Sam and Joe watched strongman Clevio Massimo perform at Portland's Hippodrome Theater and came home inspired — pouring cement into cans and bending pipes into barbells.
        </p>
        <blockquote class="vintage-quote">
          "We couldn't afford to buy weights in those days — so we made our own."
          <footer style="font-size: 0.85rem; color: var(--color-warm-gray); margin-top: 0.5rem; font-style: normal;">
            — Joe Loprinzi
          </footer>
        </blockquote>
        <p style="color: var(--color-charcoal); line-height: 1.75; margin-bottom: 2rem; font-size: 1rem;">
          In 1946, their family was dubbed <strong>"The Strongest Family in America."</strong>
          In 1948, Sam opened the gym that would become Portland's most beloved fitness institution.
          In 2014, Bob Hill — who has been lifting here since 1965 — became the steward of that legacy.
        </p>
        <a
          href={base + "/history"}
          style="display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--font-display); font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-coral); font-size: 0.9rem; text-decoration: none; border-bottom: 2px solid var(--color-coral); padding-bottom: 0.1rem; transition: color 0.2s, border-color 0.2s;"
        >
          Read the Full History
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
      <div style="position: relative;">
        <img
          src={base + "/images/gym-panorama.jpg"}
          alt="Loprinzi's Gym — the legendary iron paradise of Portland"
          width="700"
          height="500"
          loading="lazy"
          style="width: 100%; height: 400px; object-fit: cover; border-radius: 2px; box-shadow: 8px 8px 0 var(--color-navy);"
        />
        <div style="position: absolute; bottom: -1.5rem; left: -1.5rem; background: var(--color-navy); padding: 1rem 1.5rem;">
          <p style="font-family: var(--font-display); font-weight: 800; font-size: 1.1rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-gold); margin: 0; line-height: 1.2;">
            Portland's<br />
            <span style="color: #fff;">Strongest Family</span>
          </p>
          <p style="font-family: var(--font-display); font-size: 0.75rem; color: rgba(245,240,235,0.5); text-transform: uppercase; letter-spacing: 0.08em; margin: 0.25rem 0 0;">
            Since 1948
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Famous visitors -->
  <section style="padding: 4rem 1.5rem; background: var(--color-cream);" aria-labelledby="visitors-heading">
    <div style="max-width: 1200px; margin: 0 auto; text-align: center;">
      <p class="section-subtitle" style="margin-bottom: 0.5rem;">Iron Royalty Has Trained Here</p>
      <h2 id="visitors-heading" class="section-title" style="font-size: clamp(1.5rem, 4vw, 2.5rem); margin-bottom: 1rem;">
        Portland's Elite Have Called This Home
      </h2>
      <p style="color: var(--color-warm-gray); max-width: 560px; margin: 0 auto 3rem; font-size: 0.95rem; line-height: 1.7;">
        Champions, legends, and athletes — they've all felt the Loprinzi difference.
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: 2rem; justify-content: center; align-items: center;">
        {[
          { name: "Arnold Schwarzenegger", note: "Autographed photo on wall" },
          { name: "Ken Patera", note: "Olympic weightlifter" },
          { name: "Bill Walton", note: "NBA legend" },
          { name: "Jesse Ventura", note: "Wrestler & governor" },
          { name: "Lloyd Neal", note: "Trail Blazers center" },
        ].map(person => (
          <div style="text-align: center; min-width: 140px;">
            <div style="width: 72px; height: 72px; border-radius: 50%; background: var(--color-navy); margin: 0 auto 0.75rem; display: flex; align-items: center; justify-content: center;">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
            </div>
            <p style="font-family: var(--font-display); font-weight: 700; font-size: 0.95rem; letter-spacing: 0.04em; color: var(--color-navy); margin: 0 0 0.25rem;">{person.name}</p>
            <p style="font-size: 0.75rem; color: var(--color-warm-gray); margin: 0;">{person.note}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quick hours + CTA bar -->
  <section style="background: var(--color-navy); padding: 2.5rem 1.5rem;" aria-label="Hours and contact">
    <div style="max-width: 1200px; margin: 0 auto; display: flex; flex-wrap: wrap; gap: 2rem; align-items: center; justify-content: space-between;">
      <div style="display: flex; flex-wrap: wrap; gap: 3rem;">
        <div>
          <p style="font-family: var(--font-display); font-weight: 700; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-gold); margin-bottom: 0.5rem;">Hours</p>
          <p style="color: var(--color-cream); font-size: 0.9rem; margin: 0; line-height: 1.8;">
            Mon – Fri &nbsp;·&nbsp; 6:00 am – 9:00 pm<br/>
            Saturday &nbsp;·&nbsp; 7:30 am – 5:00 pm<br/>
            Sunday &nbsp;·&nbsp; 8:00 am – 5:00 pm
          </p>
        </div>
        <div>
          <p style="font-family: var(--font-display); font-weight: 700; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-gold); margin-bottom: 0.5rem;">Location</p>
          <p style="color: var(--color-cream); font-size: 0.9rem; margin: 0; line-height: 1.8;">
            2414 SE 41st Ave<br/>
            Portland, Oregon 97214<br/>
            <span style="color: rgba(245,240,235,0.5); font-size: 0.8rem;">Just off Division</span>
          </p>
        </div>
        <div>
          <p style="font-family: var(--font-display); font-weight: 700; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-gold); margin-bottom: 0.5rem;">Call Us</p>
          <a href="tel:+15032328311" style="color: #fff; font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; letter-spacing: 0.04em; text-decoration: none;">
            503-232-8311
          </a>
        </div>
      </div>
      <a
        href={base + "/contact"}
        style="display: inline-block; background: var(--color-coral); color: #fff; font-family: var(--font-display); font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 1rem 2rem; font-size: 0.95rem; text-decoration: none; white-space: nowrap;"
      >
        Get Directions
      </a>
    </div>
  </section>

</Layout>

<style>
  @media (max-width: 768px) {
    section > div[style*="grid-template-columns: 1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
