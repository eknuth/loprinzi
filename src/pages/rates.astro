---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const standardRates = [
  { period: "Single Day", standard: "$15", senior: "$15" },
  { period: "1 Month", standard: "$45", senior: "$40" },
  { period: "6 Weeks", standard: "$70", senior: "$65" },
  { period: "3 Months", standard: "$120", senior: "$100" },
  { period: "6 Months", standard: "$200", senior: "$180" },
  { period: "1 Year", standard: "$375", senior: "$350" },
];

const groupRates = [
  { period: "1 Month", couples: "$40 / each", group: "$35 / each" },
  { period: "6 Weeks", couples: "$65 / each", group: "$60 / each" },
  { period: "3 Months", couples: "$100 / each", group: "$90 / each" },
  { period: "6 Months", couples: "$180 / each", group: "$170 / each" },
  { period: "1 Year", couples: "$350 / each", group: "$325 / each" },
];
---

<Layout
  title="Membership Rates"
  description="Loprinzi's Gym membership rates — no contracts, no initiation fees. Punch cards, monthly, and annual memberships available."
>

  <!-- Hero -->
  <div style="background: var(--color-navy); padding: 5rem 1.5rem 4rem; position: relative; overflow: hidden;">
    <div style="position: absolute; inset: 0; background: repeating-linear-gradient(45deg, rgba(255,255,255,0.01) 0, rgba(255,255,255,0.01) 1px, transparent 0, transparent 50%); background-size: 20px 20px;"></div>
    <div style="max-width: 800px; margin: 0 auto; position: relative; z-index: 1;">
      <p class="section-subtitle" style="margin-bottom: 0.75rem;">Simple &amp; Fair</p>
      <h1 style="font-family: var(--font-display); font-weight: 900; font-size: clamp(2.5rem, 8vw, 5rem); text-transform: uppercase; letter-spacing: 0.06em; color: #fff; line-height: 0.95; margin-bottom: 1.5rem;">
        Membership<br/><span style="color: var(--color-gold);">Rates</span>
      </h1>
      <p style="font-size: 1.1rem; color: rgba(245,240,235,0.75); max-width: 520px; line-height: 1.75;">
        We've believed in fair, accessible fitness since 1948. No contracts. No initiation fees.
        No surprises on your bill. Just honest rates for honest work.
      </p>
    </div>
  </div>

  <!-- No contracts banner -->
  <div class="red-banner" style="font-size: 1.2rem; padding: 1.25rem 1.5rem;">
    No Contracts &nbsp;·&nbsp; No Initiation Fees &nbsp;·&nbsp; No Surprises
  </div>

  <!-- Punch card highlight -->
  <section style="padding: 4rem 1.5rem; background: var(--color-cream);" aria-labelledby="punch-card-heading">
    <div style="max-width: 1100px; margin: 0 auto;">
      <div style="background: var(--color-navy); padding: 3rem; display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center;" class="punch-card-grid">
        <div>
          <p style="font-family: var(--font-display); font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; font-size: 0.8rem; color: var(--color-gold); margin-bottom: 0.75rem;">
            Best for Flexible Lifters
          </p>
          <h2 id="punch-card-heading" style="font-family: var(--font-display); font-weight: 900; font-size: clamp(2rem, 5vw, 3rem); text-transform: uppercase; letter-spacing: 0.06em; color: #fff; line-height: 1; margin-bottom: 1rem;">
            Punch Card
          </h2>
          <p style="color: rgba(245,240,235,0.75); font-size: 1rem; line-height: 1.7; max-width: 380px;">
            Perfect if you don't make it in every week. Buy your card, use it whenever.
            There's no expiration date — just good iron waiting for you.
          </p>
        </div>
        <div style="text-align: center;">
          <div style="display: inline-flex; flex-direction: column; align-items: center; background: rgba(255,255,255,0.05); border: 2px solid var(--color-gold); padding: 2.5rem 3rem;">
            <p style="font-family: var(--font-display); font-weight: 900; font-size: 5rem; color: var(--color-gold); margin: 0; line-height: 1;">$60</p>
            <p style="font-family: var(--font-display); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.9rem; color: #fff; margin: 0.5rem 0 0;">10 Visits</p>
            <div style="width: 40px; height: 2px; background: var(--color-coral); margin: 0.75rem auto;"></div>
            <p style="font-size: 0.8rem; color: rgba(245,240,235,0.5); text-transform: uppercase; letter-spacing: 0.08em; margin: 0; font-family: var(--font-display);">
              Does Not Expire
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Rate tables -->
  <section style="padding: 0 1.5rem 5rem; background: var(--color-cream);" aria-labelledby="rates-heading">
    <div style="max-width: 1100px; margin: 0 auto;">

      <div style="text-align: center; margin-bottom: 3rem;">
        <h2 id="rates-heading" class="section-title" style="font-size: clamp(2rem, 5vw, 2.75rem);">
          Membership Options
        </h2>
        <p style="color: var(--color-warm-gray); font-size: 1rem; max-width: 500px; margin: 0.75rem auto 0; line-height: 1.7;">
          Whether you're coming for a day or committing to a year, we have a plan for you.
        </p>
      </div>

      <!-- Standard + Senior/Student -->
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 2rem;" class="table-grid">

        <!-- Standard -->
        <div class="card" style="overflow: hidden;">
          <div style="background: var(--color-navy); padding: 1.25rem 1.5rem;">
            <h3 style="font-family: var(--font-display); font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; font-size: 1rem; color: #fff; margin: 0;">Standard Rates</h3>
          </div>
          <table class="rates-table" aria-label="Standard membership rates">
            <thead>
              <tr>
                <th scope="col">Period</th>
                <th scope="col">Rate</th>
              </tr>
            </thead>
            <tbody>
              {standardRates.map(row => (
                <tr>
                  <td>{row.period}</td>
                  <td style="color: var(--color-navy); font-weight: 700; font-size: 1.05rem; font-family: var(--font-display);">{row.standard}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Senior/Student -->
        <div class="card" style="overflow: hidden;">
          <div style="background: var(--color-sage); padding: 1.25rem 1.5rem;">
            <h3 style="font-family: var(--font-display); font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; font-size: 1rem; color: #fff; margin: 0;">Senior &amp; Student Rates</h3>
          </div>
          <table class="rates-table" aria-label="Senior and student membership rates">
            <thead>
              <tr>
                <th scope="col">Period</th>
                <th scope="col">Rate</th>
              </tr>
            </thead>
            <tbody>
              {standardRates.map(row => (
                <tr>
                  <td>{row.period}</td>
                  <td style="color: var(--color-sage-dark); font-weight: 700; font-size: 1.05rem; font-family: var(--font-display);">{row.senior}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Couples + Groups -->
      <div class="card" style="overflow: hidden; margin-bottom: 3rem;">
        <div style="background: var(--color-coral); padding: 1.25rem 1.5rem;">
          <h3 style="font-family: var(--font-display); font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; font-size: 1rem; color: #fff; margin: 0;">
            Couples &amp; Group Rates
          </h3>
        </div>
        <div style="overflow-x: auto;">
          <table class="rates-table" aria-label="Couples and group membership rates" style="min-width: 500px;">
            <thead>
              <tr>
                <th scope="col">Period</th>
                <th scope="col">Couples (each)</th>
                <th scope="col">Groups 3+ (each)</th>
              </tr>
            </thead>
            <tbody>
              {groupRates.map(row => (
                <tr>
                  <td>{row.period}</td>
                  <td style="color: var(--color-coral-dark); font-weight: 700; font-family: var(--font-display);">{row.couples}</td>
                  <td style="color: var(--color-navy); font-weight: 700; font-family: var(--font-display);">{row.group}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Notes -->
      <div style="background: var(--color-cream-dark); padding: 2rem; border-left: 4px solid var(--color-gold);">
        <h3 style="font-family: var(--font-display); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.9rem; color: var(--color-navy); margin-bottom: 1rem;">
          Good to Know
        </h3>
        <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.6rem;">
          {[
            "No contracts or initiation fees — ever.",
            "Punch cards never expire. Use them at your own pace.",
            "Senior & student rates available — ask at the desk.",
            "Group rates apply for 3 or more members joining together.",
            "Questions? Call us: 503-232-8311 or email loprinzisgym@yahoo.com",
          ].map(note => (
            <li style="display: flex; align-items: flex-start; gap: 0.75rem; font-size: 0.95rem; color: var(--color-charcoal); line-height: 1.6;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-gold)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0; margin-top: 0.1rem;">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 8v4M12 16h.01"/>
              </svg>
              {note}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background: var(--color-navy); padding: 4rem 1.5rem; text-align: center;">
    <div style="max-width: 600px; margin: 0 auto;">
      <h2 style="font-family: var(--font-display); font-weight: 900; font-size: clamp(1.75rem, 5vw, 3rem); text-transform: uppercase; letter-spacing: 0.06em; color: #fff; margin-bottom: 1rem;">
        Ready to Train?
      </h2>
      <p style="color: rgba(245,240,235,0.7); font-size: 1rem; line-height: 1.7; margin-bottom: 2rem;">
        Just come in. No appointment needed. We're open 6 days a week starting at 6am.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href={base + "/contact"} style="display: inline-block; background: var(--color-coral); color: #fff; font-family: var(--font-display); font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.875rem 2rem; font-size: 0.95rem; text-decoration: none;">
          Get Directions
        </a>
        <a href={base + "/classes"} style="display: inline-block; border: 2px solid rgba(245,240,235,0.4); color: var(--color-cream); font-family: var(--font-display); font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.875rem 2rem; font-size: 0.95rem; text-decoration: none;">
          Class Schedule
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  @media (max-width: 700px) {
    .punch-card-grid {
      grid-template-columns: 1fr !important;
    }
    .table-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
